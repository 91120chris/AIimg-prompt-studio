APP_ENV=development
BACKEND_HOST=127.0.0.1
BACKEND_PORT=17321
STORAGE_ROOT=storage
DATABASE_URL=
SELECTED_AGENT_PROVIDER=codex_cli
SELECTED_IMAGE_PROVIDER=codex_cli_gpt_image

CORS_ALLOW_ORIGINS=http://localhost:1420,http://127.0.0.1:1420,http://localhost:5173,http://127.0.0.1:5173,tauri://localhost

HF_TOKEN=
HF_HOME=
HF_HUB_CACHE=

FLUX_MODEL_REPO_ID=black-forest-labs/FLUX.2-klein-9b-fp8
FLUX_MODEL_REVISION=
FLUX_MODEL_LOCAL_DIR=local_models/huggingface/flux2-klein-9b-fp8
FLUX_DEVICE_MAP=balanced
FLUX_TORCH_DTYPE=bfloat16

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_SELECTED_MODEL=
OLLAMA_TIMEOUT_SECONDS=300
OLLAMA_AGENT_TEMPERATURE=0.2

CODEX_BINARY_PATH=codex
CODEX_DEFAULT_MODEL=gpt-5.5
CODEX_MODEL_OPTIONS=gpt-5.5,gpt-5.4,gpt-5.4-mini,gpt-5.3-codex,gpt-5.3-codex-spark,gpt-5.2
CODEX_DEFAULT_REASONING_EFFORT=medium
CODEX_REASONING_EFFORT_OPTIONS=low,medium,high,xhigh
CODEX_DEFAULT_REASONING_SUMMARY=auto
CODEX_DEFAULT_VERBOSITY=
CODEX_TIMEOUT_SECONDS=300

RUN_CODEX_SMOKE=0

FRONTEND_API_BASE_URL=http://127.0.0.1:17321
